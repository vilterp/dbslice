{
  "name": "duckdb-explore",
  "version": "1.0.0",
  "description": "DuckDB data exploration UI",
  "main": "server/index.ts",
  "scripts": {
    "dev": "concurrently \"yarn server:dev\" \"yarn client:dev\"",
    "server:dev": "nodemon --exec ts-node server/index.ts",
    "server:build": "tsc --project server/tsconfig.json",
    "client:dev": "cd client && yarn dev",
    "build": "yarn server:build && cd client && yarn build",
    "start": "node server/dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "duckdb": "^1.0.0",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.1"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "ts-node": "^10.9.0",
    "@types/node": "^20.0.0",
    "@types/express": "^4.17.17",
    "@types/cors": "^2.8.13",
    "jest": "^28.0.0",
    "@types/jest": "^28.0.0",
    "ts-jest": "^28.0.0",
    "supertest": "^6.3.0",
    "@types/supertest": "^2.0.12"
  },
  "keywords": ["duckdb", "data-exploration", "react"],
  "author": "",
  "license": "MIT"
}
